{
  "Smtp": {
    "Port": 25,
    "ServerName": "InviaSignature.invia.eu",
    "MaxMessageSizeKb": 35840,
    "TlsCertificatePath": "/app/certs/smtp.pfx",
    "TlsCertificatePassword": "",
    "AllowedClientCidrs": [
      "40.92.0.0/15",
      "40.107.0.0/16",
      "52.100.0.0/14",
      "104.47.0.0/17"
    ]
  },

  "Forwarding": {
    "SmtpHost": "rockawaytravel.mail.protection.outlook.com",
    "SmtpPort": 25,
    "UseTls": true,
    "TimeoutSeconds": 30,
    "MaxRetries": 5,
    "RetryBaseDelaySeconds": 10
  },

  "Storage": {
    "BasePath": "/data",
    "PendingFolder": "pending",
    "PoisonFolder": "poison"
  },

  "Processing": {
    "BatchSize": 20,
    "IdlePollIntervalSeconds": 2,
    "ActivePollIntervalMs": 100,
    "MaxRetries": 10,
    "LoopPreventionHeader": "X-Signature-Applied",
    "InternalDomains": [],
    "CircuitBreakerThreshold": 5,
    "CircuitBreakerRecoverySeconds": 60
  },

  "HealthCheck": {
    "Port": 8080
  },

  "Signature": {
    "TemplatesPath": "templates",
    "Rules": [
      {
        "Id": "default-all",
        "Name": "Corporate signature for all outbound email",
        "Enabled": true,
        "Priority": 100,
        "Conditions": {
          "SenderPatterns": [ "*" ],
          "RecipientScope": "All",
          "MessageTypes": [],
          "Skip": {
            "SkipEncrypted": true,
            "SkipAlreadySigned": true,
            "SkipNoBody": true
          }
        },
        "TemplateId": "default",
        "Placement": "BeforeQuotedReply"
      }
    ],
    "Templates": [],
    "SenderIdentities": [],
    "DefaultIdentity": {
      "DisplayName": "",
      "Title": "",
      "Department": "",
      "Phone": "",
      "Company": "Invia",
      "Website": "https://www.invia.eu"
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/signature-service-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  }
}
