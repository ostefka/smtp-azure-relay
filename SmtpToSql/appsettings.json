{
  "Smtp": {
    "Port": 25,
    "ServerName": "smtp-crm.yourcompany.com",
    "MaxMessageSizeKb": 35840
  },
  "Sql": {
    "ConnectionString": "Server=YOUR_SQL_SERVER;Database=CrmEmail;Trusted_Connection=True;TrustServerCertificate=True;",
    "BatchSize": 50,
    "ProcessingIntervalSeconds": 5
  },
  "FallbackStorage": {
    "Path": "C:\\SmtpToSql\\Fallback"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "C:\\SmtpToSql\\Logs\\smtptosql-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  }
}
